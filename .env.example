# Create a free app at https://developer.spotify.com/dashboard to get these.
# Only needed if you want to paste Spotify playlist URLs instead of plain text/CSV.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must exactly match a Redirect URI you added in the Spotify app's Settings.
# Only change this if you're running the app on a different port than 5001.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5001/callback
